# https://ghostty.org/docs/config.

background = 15191e
foreground = feffff
background-opacity = 0.95
macos-titlebar-style = hidden

font-family = Monaco
font-size = 13
font-thicken = true

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Emacs word navigation (readline)
keybind = super+d=unbind
keybind = super+b=esc:b
keybind = super+f=esc:f
keybind = super+d=esc:d
keybind = super+backspace=esc:backspace

# Map Ctrl+Enter to send a standard carriage return
# Fix sending ;5;13~ to the terminal
keybind = ctrl+enter=text:\r
